  "type": "drupal-module",
  "license": "GPL-2.0-or-later",
  "homepage": "https://github.com/webfer/extend_accessibility_webform",
  "support": {
    "issues": "https://github.com/webfer/extend_accessibility_webform/issues",
    "source": "https://github.com/webfer/extend_accessibility_webform"
  },
  "require": {
    "drupal/core": "^10 || ^11"
  },
  "keywords": [
    "drupal",
    "drupal-module",
    "accessibility",
    "a11y",
    "webform",
    "clientside-validation",
    "aria",
    "validation"
  ]
}
